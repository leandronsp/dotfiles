#!/bin/bash
# Receives selected text from tmux copy-pipe on stdin.
# Saves selection, then triggers a popup for the comment.

SELFILE="/tmp/.claude-sel"

# Read selection from stdin
cat > "$SELFILE"

# Trigger popup with bash -i so it stays open
tmux display-popup -E -w 80 -h 6 -T " comment (Enter to submit, Esc to cancel) " \
  "bash -c 'read -r -p \"> \" comment; ~/.local/bin/claude-append \"\$comment\"'"
