#!/usr/bin/env bash
# Worktree menu for the current repo (from the active pane's cwd). Generic git
# worktrees, no project coupling. Native tmux display-menu, no fzf.
# Shortcut keys skip g/h/j/k/l/q so hjkl stays free for vi-style navigation.
#   (main)          list worktrees: ● open (jump) / ○ closed (open window) + actions
#   --rename-menu   pick an open worktree, rename ITS window
#   --delete        pick a worktree to remove; reshows after each (fast sequential)
#   --create NAME   git worktree add <repo>/.worktrees/NAME and open a window
#   --remove PATH   git worktree remove PATH, close its window, reshow --delete

GREEN="#7A9A5E"; FG="#D3C6AA"; DIM="#859289"; RED="#E67E80"; YEL="#DBBC7F"
chars="123456789abcdefimnoprstuvwxyz"   # no g/h/j/k/l/q (vi-nav keys)
mode="${1:-main}"

cwd="${WT_CWD:-$(tmux display-message -p '#{pane_current_path}')}"
common=$(git -C "$cwd" rev-parse --git-common-dir 2>/dev/null) || {
  tmux display-message "not in a git repo"; exit 0
}
case "$common" in /*) ;; *) common="$cwd/$common" ;; esac
main_root=$(cd "$(dirname "$common")" 2>/dev/null && pwd)
reponame=$(basename "$main_root")
wt_base="$main_root/.worktrees"

panes=$(tmux list-panes -a -F '#{session_name}:#{window_index}|#{pane_current_path}')
open_win_for() {  # echo session:window of a window whose pane sits in $1
  local wp="$1" sw path
  while IFS='|' read -r sw path; do
    case "$path" in "$wp"|"$wp"/*) echo "$sw"; return 0 ;; esac
  done <<< "$panes"
  return 1
}

if [ "$mode" = "--create" ]; then
  name="$2"
  [ -z "$name" ] && { tmux display-message "create: empty name"; exit 0; }
  mkdir -p "$wt_base"
  if git -C "$main_root" show-ref --verify --quiet "refs/heads/$name"; then
    out=$(git -C "$main_root" worktree add "$wt_base/$name" "$name" 2>&1)
  else
    out=$(git -C "$main_root" worktree add "$wt_base/$name" -b "$name" 2>&1)
  fi
  [ $? -ne 0 ] && { tmux display-message "worktree add failed: $out"; exit 0; }
  tmux new-window -c "$wt_base/$name" -n "$name"
  tmux display-message "created worktree $name"
  exit 0
fi

if [ "$mode" = "--remove" ]; then
  path="$2"
  win=$(open_win_for "$path")
  out=$(git -C "$main_root" worktree remove "$path" 2>&1)
  if [ $? -ne 0 ]; then tmux display-message "remove failed: $out"; exit 0; fi
  [ -n "$win" ] && tmux kill-window -t "$win" 2>/dev/null
  tmux display-message "removed $(basename "$path")"
  "$HOME/.local/bin/tmux-worktree-menu" --delete   # reshow for fast sequential delete
  exit 0
fi

# parse this repo's worktrees (skip the main checkout)
wt_path=(); wt_name=(); wt_br=(); wt_open=()
cur_path=""; cur_br=""
while IFS= read -r line; do
  case "$line" in
    worktree\ *) cur_path="${line#worktree }"; cur_br="" ;;
    branch\ *)   cur_br="${line#branch refs/heads/}" ;;
    detached)    cur_br="(detached)" ;;
    "")
      [ -z "$cur_path" ] && continue
      [ "$cur_path" = "$main_root" ] && { cur_path=""; continue; }
      brs="$cur_br"; [ ${#brs} -gt 32 ] && brs="${brs:0:30}…"
      wt_path+=("$cur_path"); wt_name+=("$(basename "$cur_path")")
      wt_br+=("$brs"); wt_open+=("$(open_win_for "$cur_path")")
      cur_path=""; cur_br=""
      ;;
  esac
done < <(git -C "$main_root" worktree list --porcelain; echo)

if [ "$mode" = "--rename-menu" ]; then
  args=(); i=0
  for j in "${!wt_path[@]}"; do
    [ -z "${wt_open[$j]}" ] && continue
    target="${wt_open[$j]}"
    wname=$(tmux display-message -t "$target" -p '#W')
    k="${chars:$i:1}"; i=$((i + 1))
    args+=("#[fg=$FG]✎ #[fg=$DIM]$target #[fg=$FG]${wt_name[$j]}#[default]" "$k" \
      "command-prompt -p \"rename $target:\" -I \"$wname\" \"rename-window -t $target -- '%%'\"")
  done
  [ ${#args[@]} -eq 0 ] && { tmux display-message "no open worktree windows"; exit 0; }
  tmux display-menu -T "#[align=centre] rename worktree window " -x C -y C "${args[@]}"
  exit 0
fi

if [ "$mode" = "--delete" ]; then
  args=(); i=0
  for j in "${!wt_path[@]}"; do
    k="${chars:$i:1}"; i=$((i + 1))
    open_tag=""; [ -n "${wt_open[$j]}" ] && open_tag="#[fg=$DIM] (${wt_open[$j]})"
    args+=("#[fg=$RED]✗ #[fg=$FG]${wt_name[$j]}#[fg=$DIM]  ${wt_br[$j]}$open_tag#[default]" "$k" \
      "run-shell \"$HOME/.local/bin/tmux-worktree-menu --remove ${wt_path[$j]}\"")
  done
  [ ${#args[@]} -eq 0 ] && { tmux display-message "no worktrees"; exit 0; }
  tmux display-menu -T "#[align=centre,fg=$RED] delete worktree · $reponame  (Esc quando acabar) " -x C -y C "${args[@]}"
  exit 0
fi

# main menu: full worktree list, open first then closed, plus actions
args=(); i=0
for j in "${!wt_path[@]}"; do
  [ -z "${wt_open[$j]}" ] && continue
  k="${chars:$i:1}"; i=$((i + 1))
  args+=("#[fg=$GREEN]● #[fg=$DIM]${wt_open[$j]} #[fg=$FG]${wt_name[$j]}#[fg=$DIM]  ${wt_br[$j]}#[default]" "$k" \
    "switch-client -t ${wt_open[$j]}")
done
for j in "${!wt_path[@]}"; do
  [ -n "${wt_open[$j]}" ] && continue
  k="${chars:$i:1}"; i=$((i + 1))
  args+=("#[fg=$YEL]○ #[fg=$FG]${wt_name[$j]}#[fg=$DIM]  ${wt_br[$j]}#[default]" "$k" \
    "new-window -c ${wt_path[$j]} -n ${wt_name[$j]}")
done
[ "$i" -eq 0 ] && args+=("#[fg=$DIM]  (sem worktrees)" "" "")

args+=("" "" "")
args+=("#[fg=$GREEN]＋ novo worktree…" "N" "command-prompt -p \"novo worktree:\" \"run-shell '$HOME/.local/bin/tmux-worktree-menu --create %%'\"")
args+=("#[fg=$FG]✎ renomear window…" "R" "run-shell \"$HOME/.local/bin/tmux-worktree-menu --rename-menu\"")
args+=("#[fg=$RED]✗ deletar worktree(s)…" "D" "run-shell \"$HOME/.local/bin/tmux-worktree-menu --delete\"")

if [ "$1" = "--dry" ]; then printf '%s\n' "${args[@]}"; exit 0; fi
tmux display-menu -T "#[align=centre] worktrees · $reponame " -x C -y C "${args[@]}"
