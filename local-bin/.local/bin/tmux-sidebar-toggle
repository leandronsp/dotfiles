#!/usr/bin/env bash
# Toggle a left-docked sidebar pane showing the live agent list (herdr-style).
# It is a real split, so the content reflows beside it; closing reclaims the space.

sb=$(tmux list-panes -F '#{pane_id} #{@is_sidebar}' | awk '$2=="1"{print $1; exit}')

if [ -n "$sb" ]; then
  tmux kill-pane -t "$sb"
else
  tmux split-window -hb -l 34 -c "#{pane_current_path}" "exec $HOME/.local/bin/tmux-sidebar"
  tmux set -p @is_sidebar 1
  tmux select-pane -R
fi
