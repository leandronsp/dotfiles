#!/bin/bash
# Appends selection + comment to the annotation buffer.

BUFFILE="/tmp/claude-buf.md"
SELFILE="/tmp/.claude-sel"
COMMENT="$1"

SEL=$(cat "$SELFILE" 2>/dev/null)
rm -f "$SELFILE"

if [ -n "$SEL" ]; then
  QUOTED=$(echo "$SEL" | sed 's/^/> /')
  if [ -n "$COMMENT" ]; then
    printf '%s\n%s\n\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n\n' "$QUOTED" "$COMMENT" >> "$BUFFILE"
  else
    printf '%s\n(sem comentario)\n\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n\n' "$QUOTED" >> "$BUFFILE"
  fi
elif [ -n "$COMMENT" ]; then
  printf '%s\n\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n\n' "$COMMENT" >> "$BUFFILE"
else
  exit 0
fi

LINES=$(wc -l < "$BUFFILE" | tr -d ' ')
tmux display-message "Annotated. ($LINES lines in buffer)"
