#!/bin/bash
# Annotation buffer popup. Opens vim for comment, appends selection (if any) + comment to buffer.

BUFFILE="/tmp/claude-buf.md"
SELFILE="/tmp/.claude-sel"
TMPFILE=$(mktemp /tmp/.claude-comment.XXXXXX)

vim -u NONE \
  +"set nocompatible noswapfile backspace=indent,eol,start ttimeoutlen=10" \
  +"startinsert" "$TMPFILE"

COMMENT=$(cat "$TMPFILE" 2>/dev/null)
rm -f "$TMPFILE"
SEL=$(cat "$SELFILE" 2>/dev/null)
rm -f "$SELFILE"

if [ -n "$SEL" ]; then
  QUOTED=$(echo "$SEL" | sed 's/^/> /')
  if [ -n "$COMMENT" ]; then
    printf '%s\n%s\n\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\n\n' "$QUOTED" "$COMMENT" >> "$BUFFILE"
  else
    printf '%s\n(sem comentario)\n\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\n\n' "$QUOTED" >> "$BUFFILE"
  fi
elif [ -n "$COMMENT" ]; then
  printf '%s\n\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\n\n' "$COMMENT" >> "$BUFFILE"
else
  exit 0
fi

LINES=$(wc -l < "$BUFFILE" | tr -d ' ')
tmux display-message "Annotated. ($LINES lines in buffer)"
