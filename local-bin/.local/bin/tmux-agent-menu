#!/usr/bin/env bash
# Native tmux display-menu of Claude Code agents across all sessions.
# Detection: Claude panes set their title to "âśł ...". Waiting agents (window
# flagged red by notify-ready.sh) are listed first with a bell.
#
# Default mode: select an agent to switch to its window. A "kill an agent"
# entry opens a submenu (--kill) that confirms before killing the agent's pane.
# Keyboard-driven, no fzf.

GREEN="#7A9A5E"; FG="#D3C6AA"; DIM="#859289"; RED="#E67E80"

wait_keys=(); wait_win=(); wait_name=(); wait_meta=(); wait_pane=()
act_keys=();  act_win=();  act_name=();  act_meta=();  act_pane=()
seen=""; maxname=0

while IFS='|' read -r pane sess win wname title; do
  case "$title" in
    *Claude\ Code*|âśł*) : ;;          # a Claude Code pane
    *) continue ;;
  esac

  key="$sess:$win"
  case " $seen " in *" $key "*) continue ;; esac   # one window per entry
  seen="$seen $key"

  meta=$(awk -F' Â· ' 'NR==1{print $1 (NF>1 ? " Â· " $2 : "")}' "/tmp/claude-statusline-$pane" 2>/dev/null)
  fmt=$(tmux show-options -wv -t "$key" window-status-format 2>/dev/null)
  [ ${#wname} -gt $maxname ] && maxname=${#wname}

  if printf '%s' "$fmt" | grep -q 'bg=red'; then
    wait_win+=("$key"); wait_name+=("$wname"); wait_meta+=("$meta"); wait_pane+=("$pane")
  else
    act_win+=("$key"); act_name+=("$wname"); act_meta+=("$meta"); act_pane+=("$pane")
  fi
done < <(tmux list-panes -a -F '#{pane_id}|#{session_name}|#{window_index}|#{window_name}|#{pane_title}')

win=("${wait_win[@]}"  "${act_win[@]}")
name=("${wait_name[@]}" "${act_name[@]}")
meta=("${wait_meta[@]}" "${act_meta[@]}")
pane=("${wait_pane[@]}" "${act_pane[@]}")
nwait=${#wait_win[@]}
total=${#win[@]}

if [ "$total" -eq 0 ]; then
  tmux display-message "no Claude agents found"
  exit 0
fi

chars="123456789abcdefghijklmnopqrstuvwxyz"
args=()
for i in $(seq 0 $((total - 1))); do
  k="${chars:$i:1}"
  sw=$(printf '%-7s' "${win[$i]}")
  nm=$(printf "%-$((maxname + 1))s" "${name[$i]}")
  bell=""; [ "$i" -lt "$nwait" ] && bell="#[fg=$RED,bold]đź”” #[nobold]"

  if [ "$1" = "--kill" ]; then
    label="#[fg=$RED]âś— #[fg=$GREEN]${sw}#[fg=$FG]${nm}#[fg=$DIM]${meta[$i]}#[default]"
    args+=("$label" "$k" "confirm-before -p \"kill ${name[$i]} (${win[$i]})? (y/n)\" \"kill-pane -t ${pane[$i]}\"")
  else
    label="${bell}#[fg=$GREEN]${sw}#[fg=$FG]${nm}#[fg=$DIM]${meta[$i]}#[default]"
    args+=("$label" "$k" "switch-client -t ${win[$i]}")
  fi
done

if [ "$1" = "--kill" ]; then
  tmux display-menu -T "#[align=centre,fg=$RED] kill which agent? " -x C -y C "${args[@]}"
  exit 0
fi

# switch menu: agents, a separator, then the kill path
args+=("" "" "")
args+=("#[fg=$RED]âś— kill an agentâ€¦" "x" "run-shell \"$HOME/.local/bin/tmux-agent-menu --kill\"")

tmux display-menu -T "#[align=centre] Claude agents " -x C -y C "${args[@]}"
